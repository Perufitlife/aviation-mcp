{
  "name": "@renzom13/aviation-mcp",
  "version": "1.0.1",
  "description": "MCP server giving AI agents (ChatGPT, Claude, Cursor) live aviation data: decoded METAR weather, airport info, aircraft specs, glossary, FAA practice questions, and a daily pilot quiz. Powered by the free Rotate Pilot API.",
  "type": "module",
  "main": "src/main.js",
  "bin": {
    "aviation-mcp": "src/stdio.js"
  },
  "scripts": {
    "start": "node src/start.js",
    "start:http": "node src/main.js",
    "start:stdio": "node src/stdio.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "agents",
    "ai",
    "claude",
    "chatgpt",
    "cursor",
    "aviation",
    "metar",
    "weather",
    "pilot",
    "airports",
    "aircraft"
  ],
  "author": "Renzo Madueno",
  "license": "MIT",
  "homepage": "https://github.com/Perufitlife/aviation-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Perufitlife/aviation-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Perufitlife/aviation-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "apify": "^3.6.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.21.0"
  }
}
